# Required
JWT_SECRET_KEY=change-me

# Optional (will fallback to notes_database/db_connection.txt if not set)
# DATABASE_URL=postgresql://appuser:dbuser123@localhost:5000/myapp

# Optional
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
APP_NAME=Notes API
APP_VERSION=1.0.0

# Comma-separated list for CORS (Next.js frontend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
